# ─────────────────────────────────────────────
#  InvestoCoach Backend – Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ── Supabase (replaces MongoDB) ───────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT (our own auth layer — independent of Supabase Auth)
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# Finnhub Market Data API  (https://finnhub.io – free tier)
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# Market Cache TTL (seconds)
MARKET_CACHE_TTL=10

# Default sandbox portfolio amount (in INR)
DEFAULT_PORTFOLIO_AMOUNT=10000

# WebSocket port (optional, falls back to HTTP port)
WS_PORT=5001

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
